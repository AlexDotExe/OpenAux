// This is your Prisma schema file
// Designed for scalability: entities support future analytics, boost payments, and multi-venue deployments

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum RequestStatus {
  PENDING
  APPROVED
  PLAYED
  SKIPPED
  DELETED
}

enum PlaybackSource {
  OPENAUX_REQUEST // Song requested by a user through OpenAux
  VENUE_SELECTED  // Song manually picked by venue admin
  PLAYLIST        // Song from a pre-loaded venue playlist
  SPONSOR         // Sponsor/anthem song
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  BOOST           // Paid song boost
  CREDIT_PURCHASE // Buying prepaid credits
  PAYOUT          // Venue payout
}

enum CreditTransactionType {
  PURCHASE   // User bought credits
  BOOST_DEBIT // Credits spent on a boost
  REFUND     // Refund for unplayed song
}

enum AdminActionType {
  OVERRIDE_QUEUE
  SKIP_SONG
  DELETE_REQUEST
  APPROVE_SUGGESTION
  REJECT_SUGGESTION
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id                String        @id @default(uuid())
  deviceFingerprint String?       @unique  // Nullable: auth users may not have a device fingerprint
  displayName       String?       // Optional DJ name shown on "DJ Alex is playing..." (#22)
  // reputationScore: derived from approval rates of submitted songs
  // Higher score = more influence weight in voting
  reputationScore   Float         @default(1.0)
  // influenceWeight is computed from reputationScore - stored for caching purposes
  influenceWeight   Float         @default(1.0)
  // Prepaid credits balance (#12)
  creditBalance     Float         @default(0.0)
  createdAt         DateTime      @default(now())

  // ── Optional auth fields (sign-in mechanism) ──
  email             String?       @unique  // Unique email for email/password sign-in
  passwordHash      String?               // bcrypt hash; null for OAuth-only accounts
  instagramId       String?       @unique  // Instagram user ID (from OAuth)
  spotifyUserId     String?       @unique  // Spotify user ID (from OAuth)
  authProvider      String?               // 'email' | 'instagram' | 'spotify' | null (null = guest)
  authToken         String?       @unique  // Session token; rotated on each sign-in

  requests          SongRequest[]
  votes             Vote[]
  sessions          UserSession[]
  creditTransactions CreditTransaction[]
  payments          Payment[]

  @@index([deviceFingerprint])
  @@index([email])
  @@index([authToken])
}

model Venue {
  id           String    @id @default(uuid())
  name         String
  // genreProfile: {"primary": "hip-hop", "secondary": ["r&b", "pop"]}
  genreProfile Json      @default("{}")
  // bpmRange: {"min": 80, "max": 140}
  bpmRange     Json      @default("{\"min\": 80, \"max\": 140}")
  // energyCurveProfile: defines how energy should evolve over a night
  // e.g. {"earlyNight": 0.4, "peakHour": 1.0, "lateNight": 0.7}
  energyCurveProfile Json @default("{\"earlyNight\": 0.4, \"peakHour\": 1.0, \"lateNight\": 0.7}")
  adminUsername String   @unique
  adminPassword String
  // streamingService: 'spotify' | 'youtube' | null — validated at the API layer
  streamingService      String?
  oauthAccessToken      String?
  oauthRefreshToken     String?
  oauthTokenExpiresAt   DateTime?
  oauthScope            String?
  connectedAccountName  String?
  connectedAccountEmail String?
  createdAt    DateTime  @default(now())
  sessions     Session[]
  blacklist    Blacklist[]

  // ── Admin controls & monetization settings ──
  defaultBoostPrice       Float   @default(1.0)    // Price to boost song (manual mode)
  maxSongRepeatsPerHour   Int     @default(3)      // Max plays per hour for same song (manual mode)
  maxSongsPerUser         Int     @default(5)      // Max pending requests per user (manual mode)
  monetizationEnabled     Boolean @default(false)  // Toggle boost feature
  smartMonetizationEnabled Boolean @default(false) // Auto-adjust pricing/limits based on user count
  revenueSharePercent     Float   @default(70.0)   // Venue's share of revenue, remainder goes to OpenAux (#11)

  // ── Content blocking (#20) ──
  blockExplicit  Boolean  @default(false)  // Block explicit/NSFW songs
  blockedGenres  String[] // Genres that cannot be requested at this venue
  blockedArtists String[] // Artists that cannot be requested at this venue

  // ── Venue control modes (#19, #21) ──
  suggestionModeEnabled Boolean @default(false) // Songs require admin approval before entering queue
  crowdControlEnabled   Boolean @default(true)  // Queue driven by crowd votes (admin can override)

  // ── Geographic & venue metadata (#29) ──
  venueType String?  // e.g. "bar", "club", "restaurant", "lounge"
  city      String?
  region    String?  // State/province
  latitude  Float?
  longitude Float?

  // ── Playlist settings (#18) ──
  // activePlaylistId: the playlist to auto-load into the queue when a session starts
  activePlaylistId String?
  // playlistPriority: when true, pre-loaded playlist songs are sorted before crowd requests
  playlistPriority Boolean @default(false)

  // ── Relations ──
  sponsorSongs     SponsorSong[]
  playlists        VenuePlaylist[]
  adminActions     AdminAction[]
  payments         Payment[]
  userSnapshots    ActiveUserSnapshot[]
  playbacks        PlaybackHistory[]

  @@index([name])
  @@index([adminUsername])
}

model Song {
  id          String        @id @default(uuid())
  spotifyId   String?       @unique
  youtubeId   String?       @unique
  title       String
  artist      String
  albumArtUrl String?
  durationMs  Int?
  bpm         Float?
  isExplicit  Boolean       @default(false) // Explicit content flag (#20)
  // genreTags: ["hip-hop", "r&b"]
  genreTags   String[]
  createdAt   DateTime      @default(now())
  requests    SongRequest[]
  playbacks   PlaybackHistory[]
  blacklists  Blacklist[]
  sponsorSongs SponsorSong[]
  playlistSongs VenuePlaylistSong[]

  @@index([spotifyId])
  @@index([youtubeId])
  @@index([artist])
}

model Session {
  id                 String          @id @default(uuid())
  venueId            String
  venue              Venue           @relation(fields: [venueId], references: [id])
  startedAt          DateTime        @default(now())
  endedAt            DateTime?
  // currentEnergyLevel: 0.0 to 1.0 — controls BPM preference and intensity
  currentEnergyLevel Float           @default(0.5)
  isActive           Boolean         @default(true)
  // simulatedUserCount: for testing smart monetization behavior
  simulatedUserCount Int             @default(0)
  // Analytics counters (#analytics)
  totalSongsPlayed   Int             @default(0) // Incremented each time a song is recorded in PlaybackHistory
  peakActiveUsers    Int             @default(0) // Highest concurrent active user count during session
  requests           SongRequest[]
  playbacks          PlaybackHistory[]
  userSessions       UserSession[]
  adminActions       AdminAction[]
  userSnapshots      ActiveUserSnapshot[]

  @@index([venueId])
  @@index([isActive])
}

// ─── User-Session Participation (#6, #7, #28) ────────────────────────────────

model UserSession {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  sessionId     String
  session       Session  @relation(fields: [sessionId], references: [id])
  joinedAt      DateTime @default(now())
  lastActiveAt  DateTime @default(now()) // Reset on any user activity (vote, request, etc.)
  expiresAt     DateTime                 // Set to joinedAt + 1 hour, reset on activity
  isExpired     Boolean  @default(false)
  // Cooldown tracking (#7) — last time this user submitted a song request
  lastRequestAt DateTime?

  @@unique([userId, sessionId])
  @@index([sessionId])
  @@index([userId])
  @@index([expiresAt])
}

// ─── Request & Voting ────────────────────────────────────────────────────────

model SongRequest {
  id         String        @id @default(uuid())
  sessionId  String
  session    Session       @relation(fields: [sessionId], references: [id])
  songId     String
  song       Song          @relation(fields: [songId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  // voteWeight: cumulative weighted score for this request
  voteWeight Float         @default(0.0)
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  votes      Vote[]
  payments   Payment[]
  // Boost monetization fields
  isBoosted    Boolean  @default(false)
  boostAmount  Float    @default(0.0)
  boostPaidAt  DateTime?
  // Refund tracking (#14)
  isRefundEligible Boolean  @default(false) // True if user paid for boost
  isRefunded       Boolean  @default(false)
  refundedAt       DateTime?
  // Playlist pre-load flag (#18) — true when added by venue playlist auto-load
  isPreloaded      Boolean  @default(false)

  @@index([sessionId, status])
  @@index([songId])
  @@index([userId])
}

model Vote {
  id        String      @id @default(uuid())
  requestId String
  request   SongRequest @relation(fields: [requestId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  // value: +1 for upvote, -1 for downvote
  value     Int
  // weight: the user's influenceWeight at time of voting
  weight    Float       @default(1.0)
  createdAt DateTime    @default(now())

  @@unique([requestId, userId])
  @@index([requestId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Playback & History ──────────────────────────────────────────────────────

model PlaybackHistory {
  id              String         @id @default(uuid())
  sessionId       String
  session         Session        @relation(fields: [sessionId], references: [id])
  venueId         String?        // Denormalized from session for analytics query performance
  venue           Venue?         @relation(fields: [venueId], references: [id])
  songId          String
  song            Song           @relation(fields: [songId], references: [id])
  playedAt        DateTime       @default(now())
  // crowdScore: aggregated vote score at time of play
  crowdScore      Float          @default(0.0)
  // skipRate: 0.0-1.0, used to penalize songs that get skipped often
  skipRate        Float          @default(0.0)
  // Source tracking (#25) — where did this song come from?
  source          PlaybackSource @default(OPENAUX_REQUEST)
  // Skip analytics (#29)
  skippedAt       DateTime?      // When the song was skipped (null if played fully)
  skipPositionMs  Int?           // How far into the song it was skipped (ms)
  // Skip initiator tracking (#analytics) — who triggered the skip?
  skipInitiatedByAdmin  Boolean  @default(false) // True if venue admin skipped, false if user-initiated
  skipInitiatedByUserId String?  // If user-initiated skip, which user

  @@index([sessionId])
  @@index([songId])
  @@index([source])
  @@index([playedAt])
  @@index([venueId, playedAt])
}

model Blacklist {
  id       String @id @default(uuid())
  venueId  String
  venue    Venue  @relation(fields: [venueId], references: [id])
  songId   String
  song     Song   @relation(fields: [songId], references: [id])
  addedAt  DateTime @default(now())

  @@unique([venueId, songId])
  @@index([venueId])
}

// ─── Monetization (#11, #12, #14) ───────────────────────────────────────────

model Payment {
  id               String        @id @default(uuid())
  userId           String?
  user             User?         @relation(fields: [userId], references: [id])
  venueId          String
  venue            Venue         @relation(fields: [venueId], references: [id])
  amount           Float         // Total amount in dollars
  type             PaymentType
  status           PaymentStatus @default(PENDING)
  stripePaymentId  String?       @unique // Stripe payment intent ID
  // Revenue split at time of transaction
  venueShareAmount   Float?      // Venue's cut
  platformShareAmount Float?     // OpenAux's cut
  // Link boost payments to the specific song request (#analytics)
  requestId        String?       // Populated for BOOST payments to identify which song was boosted
  request          SongRequest?  @relation(fields: [requestId], references: [id])
  createdAt        DateTime      @default(now())
  completedAt      DateTime?

  @@index([userId])
  @@index([venueId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@index([venueId, createdAt])
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  user        User                  @relation(fields: [userId], references: [id])
  amount      Float                 // Positive for credits in, negative for credits out
  type        CreditTransactionType
  description String?               // e.g. "Boost on 'Not Like Us'", "Purchased 10 credits"
  // Link to related payment if this was a purchase
  paymentId   String?
  // Link to related request if this was a boost debit or refund
  requestId   String?
  createdAt   DateTime              @default(now())

  @@index([userId])
  @@index([type])
}

// ─── Sponsor Songs & Promotions (#15, #23) ───────────────────────────────────

model SponsorSong {
  id                     String    @id @default(uuid())
  venueId                String
  venue                  Venue     @relation(fields: [venueId], references: [id])
  songId                 String
  song                   Song      @relation(fields: [songId], references: [id])
  // Promotion details
  promotionText          String?   // e.g. "$2 off tequila shots"
  promotionDurationMinutes Int     @default(5) // How long the promo lasts after song plays
  isActive               Boolean   @default(true)
  isAnthem               Boolean   @default(false) // Venue's signature anthem
  // Promotion activation tracking
  promotionActivatedAt   DateTime? // When the promotion was last activated (song played)
  promotionExpiresAt     DateTime? // When the active promotion expires
  // Analytics: count how many times this sponsor song's promo has been activated
  activationCount        Int       @default(0)
  createdAt              DateTime  @default(now())

  @@unique([venueId, songId])
  @@index([venueId])
}

// ─── Venue Playlists (#18) ──────────────────────────────────────────────────

model VenuePlaylist {
  id       String              @id @default(uuid())
  venueId  String
  venue    Venue               @relation(fields: [venueId], references: [id])
  name     String
  songs    VenuePlaylistSong[]
  createdAt DateTime           @default(now())

  @@index([venueId])
}

model VenuePlaylistSong {
  id         String        @id @default(uuid())
  playlistId String
  playlist   VenuePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  songId     String
  song       Song          @relation(fields: [songId], references: [id])
  position   Int           // Order in playlist

  @@unique([playlistId, songId])
  @@index([playlistId])
}

// ─── Admin Actions Log (#19, #21) ───────────────────────────────────────────

model AdminAction {
  id         String          @id @default(uuid())
  venueId    String
  venue      Venue           @relation(fields: [venueId], references: [id])
  sessionId  String
  session    Session         @relation(fields: [sessionId], references: [id])
  actionType AdminActionType
  // Optional context — what request/song was acted on
  targetRequestId String?
  metadata        Json?      // Flexible extra data (e.g. reason for rejection)
  createdAt       DateTime   @default(now())

  @@index([venueId])
  @@index([sessionId])
  @@index([actionType])
}

// ─── Analytics Snapshots (#28) ──────────────────────────────────────────────

model ActiveUserSnapshot {
  id          String   @id @default(uuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id])
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id])
  activeCount Int      // Number of active users at this point in time
  recordedAt  DateTime @default(now())

  @@index([venueId])
  @@index([sessionId])
  @@index([recordedAt])
}
